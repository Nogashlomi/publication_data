   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Load Data\n",
    "df = pd.read_csv('../DATA/02_image_clusters/full_image_data_feb_25.csv')\n",
    "books = pd.read_csv('../DATA/01_corpus_metadata/full_book_data_feb_25.csv')\n",
    "\n",
    "# 2. Define Target CKs\n",
    "target_cks = [\n",
    "    'CK_Daily Rotation of the Firmament',\n",
    "    'CK_Motion of the Eighth Sphere',\n",
    "    'CK_Complete Motion of the Eighth Sphere',\n",
    "    'CK_Complete Motion of the Eighth Sphere (Thebit)',\n",
    "    'CK_Motion of the Eighth Sphere at Boundary'\n",
    "]\n",
    "\n",
    "# 3. Calculate Unique Books per Interval\n",
    "unique_books_count = books.groupby('year_interval', observed=False)['book'].nunique()\n",
    "intervals = unique_books_count.index.astype(str)\n",
    "\n",
    "# 4. Filter and Count Books per CK\n",
    "book_counts = {\n",
    "    keyword: (\n",
    "        df[df['cks'] == keyword]\n",
    "        .groupby('year_interval', observed=False)['book']\n",
    "        .nunique()\n",
    "        .to_dict()\n",
    "    )\n",
    "    for keyword in target_cks\n",
    "}\n",
    "\n",
    "# 5. Build Result DataFrame\n",
    "book_counts_df = pd.DataFrame(book_counts, index=unique_books_count.index).fillna(0)\n",
    "book_counts_df['Books'] = unique_books_count.values\n",
    "\n",
    "# 6. Plotting - Using a wider aspect ratio to maximize the chart width\n",
    "plt.figure(figsize=(14, 7))\n",
    "\n",
    "# Plot Total Books (Baseline)\n",
    "plt.plot(intervals, unique_books_count.values, label='Total Books', \n",
    "         marker='o', color='grey', linestyle='--', alpha=0.4)\n",
    "\n",
    "# Plot each Target CK\n",
    "for keyword, data in book_counts.items():\n",
    "    keyword_values = [data.get(interval, 0) for interval in unique_books_count.index]\n",
    "    \n",
    "    # Exclude zero values from plotting to keep the lines clean\n",
    "    non_zero_values = [val for val in keyword_values if val > 0]\n",
    "    non_zero_intervals = [intervals[i] for i, val in enumerate(keyword_values) if val > 0]\n",
    "\n",
    "    if non_zero_values:\n",
    "        plt.plot(non_zero_intervals, non_zero_values, marker='o', label=keyword.replace('CK_', ''))\n",
    "\n",
    "# Final Formatting\n",
    "plt.title('Number of Unique Books per Content Group Over Time (Section 1.4)')\n",
    "plt.xlabel('Year Interval')\n",
    "plt.ylabel('Number of Unique Books')\n",
    "plt.xticks(rotation=45)\n",
    "\n",
    "# Move Legend INSIDE the plot to avoid compressing the chart width\n",
    "plt.legend(title='Content Knowledge (CK)', loc='upper left', frameon=True, framealpha=0.9)\n",
    "\n",
    "plt.grid(True, linestyle=':', alpha=0.6)\n",
    "plt.tight_layout()\n",
    "\n",
    "# 7. Save for Thesis\n",
    "save_path = '/Users/nogashlomi/projects/nog_thesis/figures/plots/source_analysis/1.4_comparison.png'\n",
    "plt.savefig(save_path, dpi=300, bbox_inches='tight')\n",
    "print(f\"High-resolution plot saved to {save_path}\")\n",
    "\n",
    "plt.show()"
   ]
  }\n",
 ],
